{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "El Club ERP",
	"version": "0.4.6",
	"identifier": "com.elclub.erp",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "El Club ERP",
				"width": 1440,
				"height": 900,
				"minWidth": 1024,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"center": true,
				"theme": "Dark"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "msi",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": [],
		"copyright": "© 2026 El Club",
		"category": "Productivity",
		"shortDescription": "Audit tool for El Club catalog",
		"longDescription": "Desktop ERP for catalog.json + SQLite audit_decisions mutations. One-user local tool.",
		"windows": {
			"wix": {
				"language": "en-US"
			},
			"nsis": null,
			"certificateThumbprint": null
		}
	}
}
